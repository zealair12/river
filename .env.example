# River app (client + server). Copy to .env — do not commit real keys.

# River API (market, assistant proxy, etc.)
PORT=3001

# Traceback branching API — Vite dev proxy maps /traceback-api → http://localhost:4000
VITE_TRACEBACK_API_URL=/traceback-api

# Optional: open full Traceback web UI from the panel link
# VITE_TRACEBACK_APP_URL=http://localhost:5173

# Third-party (only if you use those features)
# FEC_API_KEY=
# FINNHUB_API_KEY=
# NEWSAPI_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=
